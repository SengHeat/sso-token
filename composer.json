{
  "name": "sengheat/sso-token",
  "description": "Laravel SSO JWE token package — issue and verify secure tokens",
  "type": "library",
  "require": {
    "php": "^8.2",
    "web-token/jwt-framework": "^4.0",
    "predis/predis": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "SengHeat\\SsoToken\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "SengHeat\\SsoToken\\SsoTokenServiceProvider"
      ]
    }
  }
}
