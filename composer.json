{
    "name": "sengheat/laravel-sso",
    "description": "A simple and flexible Single Sign-On (SSO) package for Laravel supporting Google, GitHub, Azure AD, and any OAuth2/OpenID Connect provider.",
    "version": "2.0.2",
    "type": "library",
    "keywords": ["laravel", "sso", "oauth2", "openid", "socialite", "authentication", "google", "github", "azure"],
    "license": "MIT",
    "authors": [
        {
            "name": "Seng Heat",
            "email": "heatblack009@email.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "laravel/socialite": "^5.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.0|^11.0",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "SengHeat\\LaravelSso\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SengHeat\\LaravelSso\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "SengHeat\\LaravelSso\\SSOServiceProvider"
            ],
            "aliases": {
                "SSO": "SengHeat\\LaravelSso\\Facades\\SSO"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
