{
  "name": "sengheat/sso-token",
  "description": "SSO JWE token package for Laravel microservices",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Seng Heat",
      "email": "heatblack009@email.com"
    }
  ],
  "require": {
    "php": "^8.2",
    "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
    "web-token/jwt-framework": "^4.0",
    "predis/predis": "^2.0|^3.0"
  },
  "require-dev": {
    "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
    "phpunit/phpunit": "^10.0|^11.0"  
  },
  "autoload": {
    "psr-4": {
      "SengHeat\\SsoToken\\": "src/"
    },
    "files": [
      "src/helpers.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "SengHeat\\SsoToken\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "SengHeat\\SsoToken\\SsoTokenServiceProvider"
      ],
      "aliases": {
        "SsoAuth": "SengHeat\\SsoToken\\Facades\\SsoAuth"
      }
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}